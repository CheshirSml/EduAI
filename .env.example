# LLM Provider Configuration (GigaChat / Cloud.ru)
# Option A: Direct API Key (if using OpenAI-compatible endpoint with key)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://llm.api.cloud.ru/v1
LLM_MODEL_NAME=gigachat

# Option B: OAuth 2.0 Credentials (Standard for GigaChat)
# Get these from https://developers.sber.ru/portal/products/gigachat
GIGACHAT_CLIENT_ID=your_client_id_here
GIGACHAT_CLIENT_SECRET=your_client_secret_here
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_CHAT_URL=https://gigachat.devices.sberbank.ru/api/v2/chat/completions

# OpenWebUI Integration Settings
# The host and port where the EduAI API will listen
HOST=0.0.0.0
PORT=8000

# Application Settings
LOG_LEVEL=INFO
APP_NAME=EduAI-Core
ENVIRONMENT=development

# Homework Checker Settings
MAX_ASSIGNMENT_LENGTH=5000
MIN_SCORE_THRESHOLD=1.0
MAX_SCORE_THRESHOLD=10.0
