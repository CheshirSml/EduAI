# EduAI Local Configuration
# Скопируйте этот файл в .env и настройте под вашу среду

# =============================================================================
# ПУТИ
# =============================================================================
PROJECT_ROOT=.
DATA_ROOT=./data

# =============================================================================
# МОДЕЛЬ И ИНФЕРЕНС
# =============================================================================
# Название GGUF модели (должна быть скачана в data/models/)
DEFAULT_MODEL=Qwen3.5-4B-Q4_K_M.gguf

# Путь к исполняемому файлу llama.cpp main
LLAMA_CPP_PATH=./llama.cpp/build/bin/main

# Количество слоёв для GPU (0 = CPU only, 35 = RTX 3050)
GPU_LAYERS=35

# Количество потоков CPU
CPU_THREADS=6

# Максимальный размер контекста (токены)
MAX_CONTEXT=4096

# Таймаут инференса (секунды)
INFERENCE_TIMEOUT=300

# =============================================================================
# ОГРАНИЧЕНИЯ
# =============================================================================
# Максимальный размер файла задания (МБ)
MAX_FILE_SIZE_MB=10

# Допуск по объёму слов (%)
WORD_TOLERANCE_PCT=10

# =============================================================================
# ЛОГИРОВАНИЕ
# =============================================================================
# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Путь к файлу логов
LOG_FILE=./data/logs/homework.jsonl

# =============================================================================
# ОПЦИОНАЛЬНО: COMET ML (для экспериментов)
# =============================================================================
# Раскомментируйте и добавьте ваш ключ если используете Comet
# COMET_API_KEY=your_api_key_here
# COMET_PROJECT=eduai-local
