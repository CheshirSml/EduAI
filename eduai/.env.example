# LLM Configuration (GigaChat via Sber API - OAuth 2.0)
# Get credentials from: https://developers.sber.ru/docs/ru/gigachat/individuals-quickstart
GIGACHAT_CLIENT_ID=your_client_id_here
GIGACHAT_CLIENT_SECRET=your_client_secret_here
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# GigaChat API URLs (default, do not change unless using custom endpoint)
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_CHAT_URL=https://gigachat.devices.sberbank.ru/api/v1/chat/completions

# Application Settings
HOST=0.0.0.0
PORT=8000
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development

# Model Configuration
LLM_MODEL_NAME=GigaChat

# OpenWebUI Compatibility
ENABLE_STREAMING=true

# Homework checking parameters
HOMEWORK_CHECKING_INTERVAL_MINUTES=5
MAX_HOMEWORK_CHECKS_PER_DAY=10

# Database (optional)
DATABASE_URL=sqlite:///./test.db
